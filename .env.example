# Supabase (set in Vercel Environment Variables)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Frontend
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=/api

# CORS — comma-separated allowed origins (defaults to localhost for dev)
CORS_ORIGINS=https://your-app.vercel.app

# CloudConvert (for PDF generation)
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# FIBA Sync Service URL (DigitalOcean droplet or localhost)
# Frontend uses this to call the FIBA sync service directly
VITE_FIBA_SERVICE_URL=http://localhost:3002
