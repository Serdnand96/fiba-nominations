# Supabase (set in Vercel Environment Variables)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Frontend
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=/api

# CORS — comma-separated allowed origins (defaults to localhost for dev)
CORS_ORIGINS=https://your-app.vercel.app

# CloudConvert (for PDF generation)
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# FIBA GDAP API subscription key (backend). REQUIRED for game sync.
# The previous value was hardcoded in source and is compromised — rotate it in
# the FIBA developer portal and set the new key here (never commit it).
FIBA_API_KEY=your_fiba_subscription_key
